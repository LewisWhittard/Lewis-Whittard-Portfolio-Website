<!DOCTYPE html>
<html lang="en">
<head>
    <link rel="icon" type="image/png" href="/Images/LMWDLogo/Optimised/LMWlogo.avif">

    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] - Lewis Whittard Software Development</title>

    <!-- Static CSS paths -->
    <link rel="stylesheet" href="/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="/css/site.css" />
    <link rel="stylesheet" href="/css/Overlay.css" />

    @if (Model.Meta == true)
    {
        <meta name="title" content="@Model.Page.Meta.MetaTitle" />
        <meta name="description" content="@Model.Page.Meta.MetaDescription" />
        <meta name="keywords" content="@string.Join(", ", Model.Page.Meta.MetaKeywords)" />
        <meta name="publish-date" content="@Model.Page.PublishDate" />
        <meta property="og:image" content="/images/@Model.Page.Meta.Content.Path" />
    }

    @if (Model.ShouldNotBeIndexed)
    {
        <meta name="robots" content="noindex, follow">
    }

    @if (Model.JsonLD != null)
    {
        <script type="application/ld+json">
@Html.Raw(Model.JsonLD)
        </script>
    }
</head>

<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container">

                <!-- Static home link -->
                <a class="navbar-brand" id="LogoLink" href="/">
                    <div style="width: 128px; height: 128px;">
                        <img src="/Images/LMWDLogo/Optimised/LMWlogo.avif" width="100%" height="100%">
                    </div>
                </a>

                <button class="navbar-toggler" type="button" data-toggle="collapse" data-target=".navbar-collapse"
                        aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">

                        <li class="nav-item">
                            <a class="nav-link text-light" id="HomeNavBarButton" href="/">Home</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link text-light" id="SoftwareDevelopmentNavBarButton"
                               href="/software-development">
                                Software Development
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link text-light" id="CreativeWorksNavBarButton"
                               href="/creative-works">
                                Creative Works
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link text-light" id="SearchNavBarButton" href="search">Search</a>
                        </li>

                        <li class="nav-item">
                            <!-- Toggle Background becomes a static link or JS action -->
                            <a class="nav-link text-light Nav-Form-Font" href="Accessibility/SetBackgroundActive" rel="nofollow">
                                Toggle Background
                            </a>
                        </li>

                    </ul>
                </div>

            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top text-muted">
        <div class="container py-3 text-center">

            <div>&copy; 2022 - @DateTime.Now.Year</div>
            <div>Lewis Matthew Whittard Software Development</div>

            <div class="mt-3 d-flex justify-content-center gap-3">
                <a target="_blank" id="Linkedin" href="https://www.linkedin.com/in/lewis-whittard-092167157/">
                    <img height="32" src="/Images/Linkedin/Optimised/Linkedin.avif" alt="LinkedIn" />
                </a>
                <a target="_blank" id="Github" href="https://github.com/LewisWhittard">
                    <img height="32" src="/Images/Github/Optimised/github-mark.avif" alt="GitHub" />
                </a>
            </div>

        </div>
    </footer>

    <!-- Static JS paths -->
    <script src="/lib/jquery/dist/jquery.min.js"></script>
    <script src="/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/js/site.js"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
