<script>
    async function setConsent(value) {
        try {
            await fetch('/api/cookie/set', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify(value)
            });

            localStorage.setItem('CookieApproved', value ? 'true' : 'false');

            const overlay = document.querySelector('.position-fixed');
            if (overlay) {
                overlay.style.display = 'none';
            }
        } catch (err) {
            console.error('Failed to set consent:', err);
        }
    }
</script>

<div class="position-fixed top-0 start-0 w-100 h-100 bg-dark bg-opacity-50
            d-flex align-items-center justify-content-center"
     style="z-index: 2000;">
    <div class="card shadow-lg border-0" style="max-width: 480px; width: 100%;">
        <div class="card-body p-4">
            <h5 class="fw-bold mb-3 text-center">Telemetry & Session Tracking</h5>

            <p class="mb-3 text-center">
                This website uses a temporary session identifier to associate related events such as
                page visits and category searches. No personal data or individual search terms are stored.
            </p>

            <p class="mb-3 text-center">
                You can choose whether to allow this technical telemetry.
            </p>

            <div class="d-flex justify-content-center gap-3 mt-4">
                <button class="btn btn-primary px-4" onclick="setConsent(true)">Accept</button>
                <button class="btn btn-outline-secondary px-4" onclick="setConsent(false)">Reject</button>
            </div>
        </div>
    </div>
</div>