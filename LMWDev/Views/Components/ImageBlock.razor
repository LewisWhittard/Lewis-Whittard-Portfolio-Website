@using Page_Library.Page.Entities.ContentBlock
@using Microsoft.AspNetCore.Components

@code {
    [Parameter]
    public Page_Library.Page.Entities.ContentBlock.ImageBlock Block { get; set; }

    private string GetAlignmentStyle()
    {
        return Block?.Alignment?.ToLower() switch
        {
            "left" => "text-align: left;",
            "right" => "text-align: right;",
            _ => "text-align: center;"
        };
    }
}

@if (!string.IsNullOrWhiteSpace(Block.URL))
{
    <div style="@GetAlignmentStyle()">
        <img src="@Block.URL" alt="@Block.Alt" style="width:100%;"/>
    </div>
}
else
{
    <p>Image not available or invalid content type.</p>
}

