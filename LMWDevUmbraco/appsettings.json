{
	"$schema": "appsettings-schema.json",
	"Serilog": {
		"MinimumLevel": {
			"Default": "Information",
			"Override": {
				"Microsoft": "Warning",
				"Microsoft.Hosting.Lifetime": "Information",
				"System": "Warning"
			}
		}
	},
	"Umbraco": {
		"CMS": {
			"Global": {
				"Id": "a69a0c45-c2eb-4499-8b4c-7644ca310351",
				"ApplicationUrl": "",
				"UseHttps": true,
				"SanitizeTinyMce": true
			},
			"Content": {
				"AllowEditInvariantFromNonDefault": true,
				"ContentVersionCleanupPolicy": {
					"EnableCleanup": true
				}
			},
			"WebRouting": {
				"UmbracoApplicationUrl": ""
			},
			"Unattended": {
				"UpgradeUnattended": true
			},
			"DeliveryApi": {
				"Enabled": true,
				"PublicAccess": false,
				"ApiKey": "PUT-YOUR-ACTUAL-DELIVERY-API-KEY-HERE"
			},
			"Runtime": {
				"Mode": "Production"
			},
			"ModelsBuilder": {
				"ModelsMode": "Nothing"
			},
			"Security": {
				"AllowConcurrentLogins": false
			}
		}
	},
	"ConnectionStrings": {
		"umbracoDbDSN": "Server=;Database=;User Id=;Password=;TrustServerCertificate=;",
		"umbracoDbDSN_ProviderName": "Microsoft.Data.SqlClient"
	}
}